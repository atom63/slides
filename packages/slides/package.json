{
  "name": "@atom63/slides",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atom63/slides.git",
    "directory": "packages/slides"
  },
  "homepage": "https://github.com/atom63/slides/tree/main/packages/slides#readme",
  "type": "module",
  "description": "Host-agnostic MDX slide presentation engine — an opinionated template grammar + token theming for building decks in MDX.",
  "keywords": [
    "slides",
    "presentation",
    "mdx",
    "react",
    "deck",
    "slideshow",
    "tailwind",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "typescript": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "types": "./src/styles/styles.d.ts",
      "default": "./src/styles/slides.css"
    },
    "./theme-defaults": {
      "types": "./src/styles/theme-defaults.d.ts",
      "default": "./src/styles/theme-defaults.css"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/styles/slides.css",
    "src/styles/theme-defaults.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@iconify/react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "@mdx-js/react": "^3.1.1",
    "@tanstack/react-virtual": "^3.14.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@atom63/biome-config": "workspace:*",
    "@atom63/tsconfig": "workspace:*",
    "@biomejs/biome": "2.4.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3",
    "vitest": "^4.1.8"
  }
}
