{
  "name": "@atom63/slides",
  "version": "0.4.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atom63/slides.git",
    "directory": "packages/slides"
  },
  "bugs": {
    "url": "https://github.com/atom63/slides/issues"
  },
  "homepage": "https://github.com/atom63/slides/tree/main/packages/slides#readme",
  "type": "module",
  "description": "Write presentations as MDX — a template grammar + token theming designed for coding agents to author decks, with a browser GUI to steer them.",
  "keywords": [
    "slides",
    "presentation",
    "mdx",
    "react",
    "deck",
    "slideshow",
    "tailwind",
    "design-system",
    "ai",
    "agent",
    "coding-agent",
    "claude"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "typescript": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "typescript": "./src/vite/index.ts",
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./editor": {
      "typescript": "./src/editor/index.ts",
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./editor/styles": {
      "types": "./src/editor/styles.d.ts",
      "default": "./src/editor/styles.css"
    },
    "./styles": {
      "types": "./src/styles/styles.d.ts",
      "default": "./src/styles/slides.css"
    },
    "./theme-defaults": {
      "types": "./src/styles/theme-defaults.d.ts",
      "default": "./src/styles/theme-defaults.css"
    },
    "./themes/dark": {
      "default": "./src/styles/themes/dark.css"
    },
    "./themes/terminal": {
      "default": "./src/styles/themes/terminal.css"
    },
    "./themes/editorial": {
      "default": "./src/styles/themes/editorial.css"
    },
    "./themes/neon": {
      "default": "./src/styles/themes/neon.css"
    },
    "./themes/bold": {
      "default": "./src/styles/themes/bold.css"
    },
    "./themes": {
      "default": "./src/styles/themes.css"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/styles/slides.css",
    "src/styles/theme-defaults.css",
    "src/styles/themes/dark.css",
    "src/styles/themes/terminal.css",
    "src/styles/themes/editorial.css",
    "src/styles/themes/neon.css",
    "src/styles/themes/bold.css",
    "src/editor/styles.css",
    "src/editor/styles.d.ts",
    "src/styles/themes.css"
  ],
  "scripts": {
    "build": "node scripts/gen-theme-bundle.mjs && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@iconify/react": "^6.0.2",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@tanstack/react-virtual": "^3.14.2",
    "acorn": "8.17.0",
    "acorn-jsx": "5.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "vite": "^5 || ^6 || ^7"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@atom63/biome-config": "workspace:*",
    "@atom63/tsconfig": "workspace:*",
    "@biomejs/biome": "2.4.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "29.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3",
    "vite": "^7.1.5",
    "vitest": "^4.1.8"
  }
}
