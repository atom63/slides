{
  "name": "@atom63/create-deck",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "description": "Scaffold a standalone deck project powered by the @atom63/slides engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/atom63/slides.git",
    "directory": "packages/create-deck"
  },
  "bugs": {
    "url": "https://github.com/atom63/slides/issues"
  },
