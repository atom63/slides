{
  "name": "@atom63/create-deck",
  "version": "0.4.3",
  "license": "MIT",
  "type": "module",
  "description": "Scaffold a standalone @atom63/slides deck — step 1 of the agent workflow: create the project your coding agent then writes as MDX.",
  "keywords": [
    "slides",
    "presentation",
    "mdx",
    "deck",
    "scaffold",
    "create",
    "ai",
    "agent",
    "coding-agent",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/atom63/slides.git",
    "directory": "packages/create-deck"
  },
  "bugs": {
    "url": "https://github.com/atom63/slides/issues"
  },
  "homepage": "https://github.com/atom63/slides/tree/main/packages/create-deck#readme",
  "bin": {
    "create-deck": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "smoke": "pnpm build && node scripts/smoke-test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0"
  },
  "devDependencies": {
    "@atom63/biome-config": "workspace:*",
    "@atom63/tsconfig": "workspace:*",
    "@biomejs/biome": "2.4.6",
    "@types/node": "^24.5.1",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3"
  }
}
