{
  "name": "@atom63/slides-editor",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atom63/slides.git",
    "directory": "packages/slides-editor"
  },
  "homepage": "https://github.com/atom63/slides/tree/main/packages/slides-editor#readme",
  "type": "module",
  "description": "GUI deck editor for @atom63/slides — live MDX preview, template palette, and theme toggle.",
  "keywords": [
    "slides",
    "editor",
    "mdx",
    "react",
    "deck",
    "presentation",
    "live-preview"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "typescript": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "types": "./src/styles.d.ts",
      "default": "./src/styles.css"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/styles.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite demo",
    "build:demo": "vite build demo",
    "preview:demo": "vite preview demo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "js-yaml": "^4.1.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "@atom63/slides": "workspace:*",
    "@mdx-js/react": "^3.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@atom63/biome-config": "workspace:*",
    "@atom63/slides": "workspace:*",
    "@atom63/tsconfig": "workspace:*",
    "@biomejs/biome": "2.4.6",
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3",
    "vite": "^7.1.5",
    "vitest": "^4.1.8"
  }
}
